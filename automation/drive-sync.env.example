# Copy to /etc/aktt/drive-sync.env (chmod 640, root:akttuser).
# Used by aktt-drive-sync.service.

AKTT_DRIVE_KEY=/etc/aktt/drive-key.json
AKTT_DRIVE_DONATIONS_ID=REPLACE_WITH_DONATIONS_SPREADSHEET_ID
AKTT_DRIVE_STD_RAFFLE_ID=REPLACE_WITH_STANDARD_RAFFLE_SPREADSHEET_ID
AKTT_DRIVE_HR_RAFFLE_ID=REPLACE_WITH_HIGH_ROLLER_RAFFLE_SPREADSHEET_ID
AKTT_DB=/home/akttuser/aktt-tracker/guildstats.db
